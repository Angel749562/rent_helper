<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <text class="title">📝 抄表收租</text>
    <button class="test-btn" size="mini" bindtap="fillTestData">测试填充</button>
  </view>

  <!-- 房间选择 -->
  <view class="form-item room-select">
    <text class="label">🏠 房间号</text>
    <picker 
      mode="selector" 
      range="{{rooms}}" 
      range-key="roomNumber" 
      value="{{roomIndex}}" 
      bindchange="onRoomChange"
    >
      <view class="picker">
        <text wx:if="{{selectedRoom}}">{{selectedRoom.building}}-{{selectedRoom.roomNumber}} ▼</text>
        <text wx:else class="placeholder">请选择房间 ▼</text>
      </view>
    </picker>
  </view>

  <!-- 租户/房间基础信息 -->
  <view class="info-card" wx:if="{{selectedRoom}}">
    <view class="info-row">
      <text class="info-label">基础租金：</text>
      <text class="info-value">{{selectedRoom.baseRent || 0}} 元/月</text>
    </view>
    <view class="info-row">
      <text class="info-label">计价标准：</text>
      <text class="info-value">电价1元/度 | 水价3元/吨</text>
    </view>
    <view class="info-row">
      <text class="info-label">上次抄表：</text>
      <text class="info-value">电表{{selectedRoom.lastElectricityReading || 0}}度 | 水表{{selectedRoom.lastWaterReading || 0}}吨</text>
    </view>
  </view>

  <!-- 电费计算 -->
  <view class="calc-card" wx:if="{{selectedRoom}}">
    <view class="calc-title">⚡ 电费计算</view>
    <view class="calc-item">
      <text class="label">上月电表：</text>
      <text class="value">{{selectedRoom.lastElectricityReading || 0}} 度</text>
    </view>
    <view class="calc-item input-row">
      <text class="label">本月电表：</text>
      <input 
        type="number"
        placeholder="请输入本月电表读数" 
        bindinput="onElectricityInput" 
        value="{{electricityReading}}"
        class="input"
      />
    </view>
    <view class="calc-item result" wx:if="{{electricityUsage > 0}}">
      <text class="label">本月用电量：</text>
      <text class="value">{{electricityUsage}} 度</text>
    </view>
    <view class="calc-item result" wx:if="{{electricityFee > 0}}">
      <text class="label">电费金额：</text>
      <text class="value fee">¥{{electricityFee}}</text>
    </view>
  </view>

  <!-- 水费计算 -->
  <view class="calc-card" wx:if="{{selectedRoom}}">
    <view class="calc-title">💧 水费计算</view>
    <view class="calc-item">
      <text class="label">上月水表：</text>
      <text class="value">{{selectedRoom.lastWaterReading || 0}} 吨</text>
    </view>
    <view class="calc-item input-row">
      <text class="label">本月水表：</text>
      <input 
        type="number"
        placeholder="请输入本月水表读数" 
        bindinput="onWaterInput" 
        value="{{waterReading}}"
        class="input"
      />
    </view>
    <view class="calc-item result" wx:if="{{waterUsage > 0}}">
      <text class="label">本月用水量：</text>
      <text class="value">{{waterUsage}} 吨</text>
    </view>
    <view class="calc-item result" wx:if="{{waterFee > 0}}">
      <text class="label">水费金额：</text>
      <text class="value fee">¥{{waterFee}}</text>
    </view>
  </view>

  <!-- 总计 -->
  <view class="total-card" wx:if="{{selectedRoom}}">
    <text class="total-label">📊 本月总计</text>
    <text class="total-amount">¥{{totalAmount || 0}}</text>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section" wx:if="{{selectedRoom}}">
    <text class="label">💰 支付方式</text>
    <view class="payment-options">
      <view 
        class="payment-option {{paymentMethod === '现金' ? 'active' : ''}}" 
        bindtap="onPaymentChange" 
        data-method="现金"
      >现金</view>
      <view 
        class="payment-option {{paymentMethod === '微信' ? 'active' : ''}}" 
        bindtap="onPaymentChange" 
        data-method="微信"
      >微信</view>
      <view 
        class="payment-option {{paymentMethod === '支付宝' ? 'active' : ''}}" 
        bindtap="onPaymentChange" 
        data-method="支付宝"
      >支付宝</view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="form-item" wx:if="{{selectedRoom}}">
    <text class="label">📝 备注</text>
    <input 
      placeholder="如：租户延期缴费、优惠5元等（选填）" 
      bindinput="onNotesInput" 
      value="{{notes}}" 
      class="input notes-input"
    />
  </view>

  <!-- 保存按钮 -->
  <button 
    class="save-btn" 
    bindtap="saveRecord" 
    wx:if="{{selectedRoom}}"
    hover-class="save-btn-hover"
  >✓ 保存抄表记录</button>

  <!-- 未选择房间时的提示 -->
  <view class="empty-tip" wx:else>
    <text>暂无房间数据，请先添加房间</text>
    <button size="mini" class="add-room-btn">去添加房间</button>
  </view>
</view>
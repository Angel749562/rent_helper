/* pages/rooms/rooms.wxss */
.container {
    padding: 30rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30rpx;
    padding: 20rpx 30rpx;
    background-color: #fff;
    border-radius: 16rpx;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .add-btn {
    background-color: #07c160 !important;
    color: #fff !important;
    font-size: 28rpx;
    height: 60rpx;
    line-height: 60rpx;
    border-radius: 30rpx;
  }
  
  .building-tabs {
    background-color: #fff;
    border-radius: 16rpx;
    padding: 20rpx;
    margin-bottom: 30rpx;
    white-space: nowrap;
  }
  
  .building-tab {
    display: inline-block;
    padding: 10rpx 30rpx;
    margin-right: 20rpx;
    background-color: #f5f5f5;
    border-radius: 40rpx;
    font-size: 28rpx;
    color: #666;
  }
  
  .building-tab.active {
    background-color: #07c160;
    color: #fff;
  }
  
  .room-list {
    margin-bottom: 30rpx;
  }
  
  .room-card {
    background-color: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  }
  
  .room-header {
    margin-bottom: 20rpx;
  }
  
  .room-info {
    display: flex;
    align-items: center;
  }
  
  .room-number {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
    margin-right: 20rpx;
  }
  
  .building-tag {
    font-size: 26rpx;
    color: #07c160;
    background-color: #e6f7e6;
    padding: 4rpx 16rpx;
    border-radius: 30rpx;
  }
  
  .room-details {
    background-color: #f8f9fa;
    padding: 20rpx;
    border-radius: 12rpx;
    margin-bottom: 20rpx;
  }
  
  .detail-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10rpx;
    font-size: 28rpx;
    color: #666;
  }
  
  .detail-row:last-child {
    margin-bottom: 0;
  }
  
  .room-actions {
    display: flex;
    gap: 20rpx;
  }
  
  .collect-btn {
    flex: 2;
    height: 70rpx;
    line-height: 70rpx;
    background-color: #07c160;
    color: #fff;
    font-size: 30rpx;
    border-radius: 35rpx;
    margin: 0;
  }
  
  .delete-btn {
    flex: 1;
    height: 70rpx;
    line-height: 70rpx;
    background-color: #fff0f0;
    color: #ff6b6b;
    font-size: 30rpx;
    border-radius: 35rpx;
    margin: 0;
  }
  
  /* 弹窗样式 */
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
  }
  
  .modal-content {
    width: 80%;
    max-width: 600rpx;
    background-color: #fff;
    border-radius: 24rpx;
    overflow: hidden;
  }
  
  .modal-header {
    padding: 30rpx;
    border-bottom: 2rpx solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .modal-header text {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .modal-header .close {
    font-size: 40rpx;
    color: #999;
    padding: 10rpx;
  }
  
  .modal-body {
    padding: 30rpx;
  }
  
  .modal-footer {
    padding: 30rpx;
    border-top: 2rpx solid #f0f0f0;
    display: flex;
    gap: 20rpx;
  }
  
  .modal-footer button {
    flex: 1;
    height: 70rpx;
    line-height: 70rpx;
    font-size: 30rpx;
    border-radius: 35rpx;
    margin: 0;
  }
  
  .cancel-btn {
    background-color: #f5f5f5;
    color: #666;
  }
  
  .confirm-btn {
    background-color: #07c160;
    color: #fff;
  }
  
  .form-item {
    margin-bottom: 30rpx;
  }
  
  .form-item .label {
    display: block;
    font-size: 30rpx;
    color: #666;
    margin-bottom: 10rpx;
  }
  
  .form-item input, .picker {
    width: 100%;
    padding: 20rpx;
    background-color: #f8f9fa;
    border-radius: 12rpx;
    font-size: 30rpx;
    box-sizing: border-box;
  }
  /* 添加到文件末尾 */
.empty-tip {
    text-align: center;
    padding: 60rpx;
    color: #999;
    font-size: 28rpx;
  }